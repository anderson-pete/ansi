{
	"compilerOptions" : {
		"module"    : "CommonJS",
		"target"    : "ESNext",
		"checkJs"   : true,
		"rootDir"   : "src",
		"strict"    : true,
		"types"     : ["node"],
		"typeRoots" : ["./node_modules/@types"]
	},
	"include"         : [
		"src/**/*.js",
		"src/**/*.d.ts"
	],
	"exclude"         : [
		"dist",
		"node_modules",
		"**/node_modules/*"
	]
}