{
	"compilerOptions": {
		"target"                           : "ES2020",
		"module"                           : "CommonJS",
		"lib"                              : ["ES2020"],
		"types"                            : ["node"],
		"rootDir"                          : ".",
		"noEmit"                           : true,
		"strict"                           : true,
		"esModuleInterop"                  : true,
		"skipLibCheck"                     : true,
		"forceConsistentCasingInFileNames" : true,
	},
}