{
	"compilerOptions": {
		"target"                           : "ES2020",
		"module"                           : "CommonJS",
		"lib"                              : ["ES2020"],
		"types"                            : ["node"],
		"declaration"                      : true,
		"declarationMap"                   : true,
		"sourceMap"                        : true,
		"rootDir"                          : "src",
		"outDir"                           : "dist",
		"strict"                           : true,
		"esModuleInterop"                  : true,
		"skipLibCheck"                     : true,
		"forceConsistentCasingInFileNames" : true,
	},
	"include": ["src"],
	"exclude": ["node_modules", "dist"],
}